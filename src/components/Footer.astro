---
---
<footer class="w-full bg-white border-t border-slate-200 mt-16 text-slate-600">
    <!-- Newsletter Section -->
    <div class="border-b border-slate-200 py-8 lg:py-12 bg-slate-50">
        <div class="container mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-primary-500 text-white rounded-full flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-slate-800 uppercase">Đăng ký nhận tin</h3>
                    <p class="text-sm">Nhận thông tin cập nhật mới nhất và ưu đãi đặc biệt.</p>
                </div>
            </div>
            <form class="flex w-full md:w-[400px] shadow-sm">
                <input type="email" placeholder="Nhập email của bạn" class="flex-grow px-4 py-3 rounded-l-md border border-slate-300 focus:outline-none focus:border-primary-500 text-sm">
                <button type="submit" class="bg-primary-500 hover:bg-primary-600 text-white px-6 py-3 rounded-r-md font-bold text-sm uppercase transition-colors">Gửi</button>
            </form>
        </div>
    </div>

    <!-- Main Footer Content -->
    <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
            <!-- Col 1: About -->
            <div class="flex flex-col gap-4">
                <a href="/" class="mb-4 block">
                    <img src="/logo.png" alt="Thể Thao Hoàng Hà" class="h-16 w-auto object-contain" />
                </a>
                <p class="text-sm leading-relaxed text-slate-600">
                    Tổng kho bán buôn, bán lẻ dụng cụ thể thao, phong cách hiện đại.
                </p>
                <div class="space-y-3 mt-2 text-sm">
                    <div class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span>1A7 Tam Giang, Hải Dương</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        <a href="tel:0964534299" class="hover:text-primary-500 font-bold transition-colors">0964.534.299 (Zalo)</a>
                    </div>
                </div>
            </div>

            <!-- Col 2: Info -->
            <div class="flex flex-col gap-4">
                <h3 class="text-secondary-500 font-bold uppercase tracking-wider text-sm mb-2">Chăm Sóc Khách Hàng</h3>
                <ul class="space-y-3 text-sm">
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Chính sách mua buôn/sỉ</a></li>
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Giao hàng & Lắp đặt tại nhà</a></li>
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Chính sách bảo hành đổi trả</a></li>
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Câu hỏi thường gặp</a></li>
                </ul>
            </div>

            <!-- Col 3: Policy -->
            <div class="flex flex-col gap-4">
                <h3 class="text-secondary-500 font-bold uppercase tracking-wider text-sm mb-2">Thông tin</h3>
                <ul class="space-y-3 text-sm">
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Giới thiệu về chúng tôi</a></li>
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Liên hệ</a></li>
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Sản phẩm khuyến mãi</a></li>
                    <li><a href="#" class="hover:text-primary-500 transition-colors">Tin tức thể thao</a></li>
                </ul>
            </div>

            <!-- Col 4: Map -->
            <div class="flex flex-col gap-4">
                <h3 class="text-secondary-500 font-bold uppercase tracking-wider text-sm mb-2">Bản Đồ</h3>
                <div class="w-full h-40 bg-slate-200 rounded-lg overflow-hidden relative group border border-slate-200">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3725.1052601704285!2d106.31557021133375!3d20.94827018903328!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31359a6136ef8fe5%3A0xcfe299cb84f18db2!2zMUE3IFRhbSBHaWFuZywgUC4gVHLhuqduIEjGsG5nIMSQ4bqhbywgVGjDoG5oIHBo4buRIEjhuqNpIETGsMahbmcsIEjhuqNpIETGsMahbmcsIFZp4buHdCBOYW0!5e0!3m2!1svi!2s!4v1714589252328!5m2!1svi!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="absolute inset-0"></iframe>
                </div>
            </div>
        </div>

        <!-- Copyright -->
        <div class="mt-12 pt-8 border-t border-slate-200 text-center text-sm text-slate-500">
            <p>&copy; {new Date().getFullYear()} Thể Thao Hoàng Hà.</p>
        </div>
    </div>
</footer>
