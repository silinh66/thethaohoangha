---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
  title = "Thể thao Hoàng Hà", 
  description = "Chuyên bán buôn, bán lẻ dụng cụ thể thao, máy tập, vợt cầu lông, bóng đá, bóng bàn chính hãng tại Hải Dương. Giá sỉ tốt nhất, bảo hành tận nơi." 
} = Astro.props;

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "SportsStore",
  "name": "Thể thao Hoàng Hà",
  "image": "https://placehold.co/600x400/e11d48/ffffff.webp?text=The+Thao+Hoang+Ha",
  "description": "Tổng kho bán buôn, bán lẻ dụng cụ thể thao uy tín số 1 tại Hải Dương.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Số 123 Đường Điện Biên Phủ",
    "addressLocality": "Hải Dương",
    "addressRegion": "Hải Dương",
    "addressCountry": "VN"
  },
  "telephone": "0987654321",
  "priceRange": "$$"
};
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.png?v=2" />
		<meta name="generator" content={Astro.generator} />
        
        <!-- SEO Metadata -->
		<title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href={Astro.site} />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.site} />
        <meta property="og:image" content="https://placehold.co/1200x630/e11d48/ffffff.webp?text=The+Thao+Hoang+Ha" />

        <!-- Schema Markup -->
        <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

        <!-- Fonts (Plus Jakarta Sans) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
        
        <!-- Crisp Chat -->
        <script type="text/javascript">window.$crisp=[];window.CRISP_WEBSITE_ID="127adc7d-0ff9-4721-a273-28eb4aba9868";$crisp.push(["set", "session:data", [[[ "language", "vi" ]]]]);$crisp.push(["safe", true]);(function(){d=document;s=d.createElement("script");s.src="https://client.crisp.chat/l.js";s.async=1;d.getElementsByTagName("head")[0].appendChild(s);})();</script>
	</head>
	<body class="min-h-screen flex flex-col">
        <Header />
        
		<main class="flex-grow flex flex-col items-center">
			<slot />
		</main>

        <Footer />
        <FloatingButtons />
	</body>
</html>
