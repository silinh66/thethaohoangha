---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
  title = "Thể Thao Hoàng Hà - Chuyên Đồ Thể Thao Chính Hãng", 
  description = "Thể thao Hoàng Hà chuyên bán buôn, bán lẻ dụng cụ thể thao, máy tập, vợt cầu lông, bóng đá, bóng bàn chính hãng giá sỉ tốt nhất tại Hải Dương. Bảo hành tận nơi.",
  image = "/favicon.png",
} = Astro.props;

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "SportsStore",
  "name": "Thể thao Hoàng Hà",
  "image": "https://thethaohoangha.com/favicon.png",
  "description": "Tổng kho bán buôn, bán lẻ dụng cụ thể thao uy tín số 1 tại Hải Dương.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Số 123 Đường Điện Biên Phủ",
    "addressLocality": "Hải Dương",
    "addressRegion": "Hải Dương",
    "addressCountry": "VN"
  },
  "telephone": "0987654321",
  "priceRange": "$$"
};
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="/favicon.png?v=2" />
		<meta name="generator" content={Astro.generator} />
        
        <!-- SEO Metadata -->
		<title>{title}</title>
        <meta name="description" content={description} />
        <meta name="author" content="Thể Thao Hoàng Hà">
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <link rel="canonical" href={Astro.site} />

        <!-- Open Graph / Facebook / Zalo / Telegram -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={Astro.site} />
        <meta property="og:site_name" content="Thể Thao Hoàng Hà" />
        <meta property="og:image" content={new URL(image, Astro.site)} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="Thể Thao Hoàng Hà" />
        <meta property="og:locale" content="vi_VN" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={new URL(image, Astro.site)} />

        <!-- Schema Markup -->
        <script type="application/ld+json" set:html={JSON.stringify(schemaMarkup)} />

        <!-- Fonts (Plus Jakarta Sans) -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
        
        <!-- Alpine.js (Client-side rendering & reactivity) -->
        <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

        <!-- Crisp Chat -->
        <script type="text/javascript">window.$crisp=[];window.CRISP_WEBSITE_ID="127adc7d-0ff9-4721-a273-28eb4aba9868";$crisp.push(["set", "session:data", [[[ "language", "vi" ]]]]);$crisp.push(["safe", true]);(function(){d=document;s=d.createElement("script");s.src="https://client.crisp.chat/l.js";s.async=1;d.getElementsByTagName("head")[0].appendChild(s);})();</script>
	</head>
	<body class="min-h-screen flex flex-col">
        <Header />
        
		<main class="flex-grow flex flex-col items-center">
			<slot />
		</main>

        <Footer />
        <FloatingButtons />

        <!-- Firebase Analytics -->
        <script type="module">
          import { initializeApp } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-app.js";
          import { getAnalytics } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-analytics.js";

          // Your web app's Firebase configuration
          const firebaseConfig = {
            apiKey: "AIzaSyCzTTripTl-dZgFN3hijkQOGJ2_CyE8ErI",
            authDomain: "thethaohoangha-site.firebaseapp.com",
            projectId: "thethaohoangha-site",
            storageBucket: "thethaohoangha-site.firebasestorage.app",
            messagingSenderId: "611899096243",
            appId: "1:611899096243:web:a5522705f2bf45895384c6",
            measurementId: "G-HD9101039L"
          };

          // Initialize Firebase
          const app = initializeApp(firebaseConfig);
          const analytics = getAnalytics(app);
        </script>
	</body>
</html>
