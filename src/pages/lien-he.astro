---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Liên hệ | Thể thao Hoàng Hà">
    <div class="w-full bg-slate-50 py-3 border-b border-slate-200">
        <div class="max-w-6xl mx-auto px-4 flex items-center text-sm">
            <a href="/" class="text-slate-500 hover:text-primary-500 transition-colors">Trang chủ</a>
            <span class="mx-2 text-slate-300">/</span>
            <span class="text-slate-900 font-medium truncate">Liên hệ</span>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-10 md:py-16">
        <h1 class="text-2xl md:text-4xl font-black text-slate-900 mb-8 uppercase text-center">Liên hệ với chúng tôi</h1>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
            <!-- Contact Info -->
            <div class="bg-slate-50 p-8 rounded-2xl border border-slate-100 flex flex-col justify-center h-full">
                <h3 class="text-2xl font-bold text-slate-800 mb-6">Thông tin liên hệ</h3>
                
                <div class="flex flex-col gap-6">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-primary-500 shadow-sm shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold text-slate-800 text-lg mb-1">Địa chỉ</p>
                            <p class="text-slate-600">1A7 Tam Giang, Hải Dương</p>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-primary-500 shadow-sm shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold text-slate-800 text-lg mb-1">Điện thoại</p>
                            <a href="tel:0964534299" class="text-slate-600 hover:text-primary-600 transition-colors">0964.534.299</a>
                        </div>
                    </div>

                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-[#0068FF] rounded-full flex items-center justify-center text-white font-bold text-xs uppercase tracking-widest shadow-sm shadow-blue-500/30 shrink-0">
                            Zalo
                        </div>
                        <div>
                            <p class="font-bold text-slate-800 text-lg mb-1">Zalo Official</p>
                            <a href="https://zalo.me/0964534299" target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-blue-600 transition-colors">Chat Zalo ngay</a>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-8 border-t border-slate-200">
                    <a href="https://zalo.me/0964534299" target="_blank" rel="noopener noreferrer" class="w-full block text-center bg-zalo hover:bg-blue-600 text-white font-bold py-4 rounded-xl transition-transform hover:-translate-y-1 shadow-lg shadow-blue-500/20">
                        Nhắn Zalo Nhận Tư Vấn Nhanh Nhất
                    </a>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)]">
                <h3 class="text-2xl font-bold text-slate-800 mb-6">Gửi tin nhắn (Qua Zalo)</h3>
                <p class="text-slate-500 mb-6">Để đảm bảo bạn được phản hồi nhanh và chính xác nhất, mọi thắc mắc và yêu cầu tư vấn xin vui lòng liên hệ trực tiếp số Zalo hotline của cửa hàng. Chúng tôi luôn sẵn sàng hỗ trợ trực tuyến 24/7.</p>
                
                <form action="https://zalo.me/0964534299" method="get" target="_blank" class="flex flex-col gap-4">
                     <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Họ Tên</label>
                        <input type="text" placeholder="Nhập họ tên của bạn" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:border-primary-500 transition-colors" required>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Số Điện Thoại</label>
                        <input type="tel" placeholder="Nhập số điện thoại" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:border-primary-500 transition-colors" required>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-2">Nội Dung Tư Vấn</label>
                        <textarea rows="4" placeholder="Nhập nội dung bạn cần hỗ trợ..." class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:border-primary-500 transition-colors" required></textarea>
                    </div>
                    <button type="submit" class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-3.5 rounded-lg transition-colors mt-2">
                        Chuyển Sang Cửa Sổ Zalo
                    </button>
                    <p class="text-xs text-center text-slate-400 mt-2">* Thông tin của bạn sẽ được chuyển tiếp qua ứng dụng Zalo để bảo mật và phản hồi nhanh.</p>
                </form>
            </div>
        </div>
    </div>
</BaseLayout>
