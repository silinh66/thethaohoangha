---
import BaseLayout from '../../layouts/BaseLayout.astro';
import productsData from '../../data/products.json';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  return productsData.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const zaloLink = `https://zalo.me/0964534299?text=Tôi+cần+mua+${encodeURIComponent(product.name)}`;
---

<BaseLayout title={`${product.name} | Thể thao Hoàng Hà`} description={product.description}>
    <!-- Breadcrumb -->
    <div class="w-full bg-slate-50 py-3 border-b border-slate-200">
        <div class="container mx-auto px-4 flex items-center text-sm">
            <a href="/" class="text-slate-500 hover:text-primary-600 transition-colors">Trang chủ</a>
            <span class="mx-2 text-slate-300">/</span>
            <span class="text-slate-900 font-medium truncate">{product.name}</span>
        </div>
    </div>

    <div class="container mx-auto px-4 py-8 lg:py-12 flex flex-col items-start gap-12 w-full">
        <!-- Main Product Section -->
        <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16">
            <!-- Left: Product Image -->
            <div class="flex flex-col gap-4">
                <div class="w-full aspect-square bg-slate-50 rounded-2xl border border-slate-200 overflow-hidden relative group">
                    <Image 
                        src={product.image} 
                        alt={product.name}
                        width={600}
                        height={600}
                        class="w-full h-full object-cover origin-center transition-transform duration-300 group-hover:scale-150 cursor-zoom-in"
                        loading="eager"
                    />
                    {product.originalPrice && (
                        <div class="absolute top-4 left-4 bg-primary-500 text-white text-sm font-bold px-3 py-1.5 rounded-md shadow-sm">
                            Giảm giá rốc
                        </div>
                    )}
                </div>
                <!-- Gallery (Mock) -->
                <div class="grid grid-cols-4 gap-3">
                    {[1, 2, 3, 4].map(() => (
                        <div class="aspect-square bg-slate-100 rounded-lg border-2 border-transparent hover:border-primary-500 cursor-pointer overflow-hidden opacity-70 hover:opacity-100 transition-all">
                             <Image 
                                src={product.image} 
                                alt={`Thumbnail of ${product.name}`}
                                width={150}
                                height={150}
                                class="w-full h-full object-cover"
                            />
                        </div>
                    ))}
                </div>
            </div>

            <!-- Right: Product Info -->
            <div class="flex flex-col h-full pl-0 md:pl-4 lg:pl-8">
                <h1 class="text-2xl md:text-3xl lg:text-4xl font-black text-slate-900 mb-2 leading-tight">
                    {product.name}
                </h1>
                
                <div class="flex items-center gap-4 mb-6">
                    <span class="text-sm text-slate-500 font-medium">Mã SP: <strong class="text-slate-800">{product.id}</strong></span>
                    <span class="text-slate-300">|</span>
                    <span class="text-sm text-slate-500 font-medium">Tình trạng: <strong class="text-green-600">Còn hàng</strong></span>
                </div>

                <!-- Price Area -->
                <div class="bg-slate-50 border border-slate-100 rounded-xl p-6 mb-8 flex flex-col gap-2">
                    <div class="flex items-end gap-3">
                        <span class="text-3xl md:text-4xl font-bold text-primary-600">{product.price}</span>
                        {product.originalPrice && (
                            <del class="text-lg text-slate-400 font-medium line-through mb-1">{product.originalPrice}</del>
                        )}
                    </div>
                </div>

                <!-- Short Description -->
                <div class="prose prose-sm text-slate-600 mb-8 border-l-4 border-slate-200 pl-4 py-1">
                    <p class="font-medium text-base">{product.description}</p>
                </div>

                <!-- Action Buttons Area -->
                 <div class="flex flex-col gap-4 mt-auto border-t border-slate-200 pt-8" id="mua-hang">
                    <a href={zaloLink} 
                       target="_blank" 
                       rel="noopener noreferrer"
                       class="w-full flex items-center justify-center gap-3 bg-zalo hover:bg-blue-600 text-white font-bold text-lg py-4 px-6 rounded-xl transition-all hover:shadow-[0_8px_30px_rgba(0,104,255,0.3)] hover:-translate-y-1">
                        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M21.1 11.2C21.1 6.5 16.5 2.7 10.9 2.7C5.3 2.7 0.7 6.5 0.7 11.2C0.7 15.1 4 18.5 8.1 19.5V22.6L12.3 20H13.6C16.6 20 19.4 18.8 20.8 17.5C21 17.4 21 17.2 21 17.2V17C21.1 16.9 21.1 16.8 21.1 16.7L21.1 11.2ZM15.4 16.2H12.9V12.7H11.2C10.6 12.7 10.1 12.2 10.1 11.6V9.9C10.1 9.3 10.6 8.8 11.2 8.8H15.4C16 8.8 16.5 9.3 16.5 9.9V15.1C16.5 15.7 16 16.2 15.4 16.2ZM12.9 11.6H11.2V9.9H12.9V11.6ZM9.9 16.2H5.7C5.1 16.2 4.6 15.7 4.6 15.1V9.9C4.6 9.3 5.1 8.8 5.7 8.8H9.9C10.5 8.8 11 9.3 11 9.9V15.1C11 15.7 10.5 16.2 9.9 16.2ZM7.4 11.6H5.7V9.9H7.4V11.6Z"/></svg>
                        <span>Chat Zalo Tư Vấn Ngay</span>
                    </a>
                    
                    <a href="tel:0964534299" 
                       class="w-full flex items-center justify-center gap-3 bg-white border-2 border-primary-600 text-primary-600 hover:bg-primary-50 font-bold text-lg py-3.5 px-6 rounded-xl transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        <span>Gọi Trực Tiếp: 0964.534.299</span>
                    </a>
                </div>

                <!-- Commitments -->
                <div class="grid grid-cols-2 gap-4 mt-8 bg-slate-50 p-6 rounded-xl border border-slate-100">
                    <div class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-sm font-medium text-slate-700">100% Chính hãng</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <span class="text-sm font-medium text-slate-700">Giao nhanh Hải Dương</span>
                    </div>
                    <div class="flex items-start gap-3">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                        <span class="text-sm font-medium text-slate-700">Bảo hành tận nhà</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                        <span class="text-sm font-medium text-slate-700">Hỗ trợ đổi trả 7 ngày</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description Tab section Bottom -->
        <div class="w-full mt-8 border-t border-slate-200 pt-12">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 border-l-4 border-primary-600 pl-4 py-1">Thông Tin Chi Tiết Sản Phẩm</h2>
            <div class="prose max-w-none text-slate-600 space-y-4">
                <p><strong>{product.name}</strong> là một trong những sản phẩm nổi bật nhất tại Thể Thao Hoàng Hà. {product.description}</p>
                <p>Sản phẩm cam kết chất lượng tốt nhất, giá cực ưu đãi. Hãy liên hệ hotline hoặc Zalo phía trên để được tư vấn nhiệt tình nhất bởi đội ngũ của Hoàng Hà Sports.</p>
                <p><em>(Nội dung mô tả mang tính chất minh họa về cấu trúc chuẩn SEO theo yêu cầu).</em></p>
                <ul>
                    <li>Thương hiệu: Chính hãng</li>
                    <li>Danh mục: {product.category}</li>
                    <li>Xuất xứ: Theo nhà sản xuất</li>
                    <li>Tình trạng: Mới 100% nguyên hộp</li>
                </ul>
            </div>
        </div>
    </div>
</BaseLayout>
