---
import BaseLayout from '../../layouts/BaseLayout.astro';
import productsData from '../../data/products.json';
import vttData from '../../data/vtt_structured.json';

export async function getStaticPaths() {
    const paths: any[] = [];

    const removeAccents = (str: string) => {
        if(!str) return '';
        return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D').toLowerCase();
    };
    const makeSlug = (str: string) => removeAccents(str).replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

    const checkProductMatch = (p: any, slug: string) => {
        // Match exact or with incremental suffix generated by tools (e.g. ao-gio-nam vs ao-gio-nam-1)
        if (p.subCategorySlugs && p.subCategorySlugs.some((s: string) => s === slug || s.startsWith(slug + '-'))) return true;
        
        if (makeSlug(p.brand || '') === slug) return true;
        if (slug === 'grendene' && p.brand === 'sp-grendene-1') return true;
        if (makeSlug(p.gender || '') === slug) return true;
        if (makeSlug(p.sport || '') === slug) return true;
        if (makeSlug(p.itemType || '') === slug) return true;
        
        // Custom case for kids
        if (slug === 'tre-em' && makeSlug(p.gender || '') === 'tre-em') return true;
        if (slug.includes('be-gai') && p.subCategorySlugs && p.subCategorySlugs.some((s: string) => s.includes('be-gai'))) return true;
        if (slug.includes('be-trai') && p.subCategorySlugs && p.subCategorySlugs.some((s: string) => s.includes('be-trai'))) return true;
        
        // Advanced Guessing fallback based on user's exact URL (e.g. ao-gio-nam, balo-nu)
        let g = makeSlug(p.gender || '');
        let t = makeSlug(p.itemType || ''); 
        let n = makeSlug(p.name || '');
        let sp = makeSlug(p.sport || '');
        
        if (t === 'phu-kien') {
            if (slug.includes('balo') && n.includes('balo')) return slug.endsWith(g) || g === 'unisex';
            if (slug.includes('tui') && n.includes('tui')) return slug.endsWith(g) || g === 'unisex';
            if (slug.includes('tat') && n.includes('tat')) return slug.endsWith(g) || g === 'unisex';
            if (slug.includes('mu') && n.includes('mu')) return slug.endsWith(g) || g === 'unisex';
            if (slug.includes('dep') && n.includes('dep')) return slug.endsWith(g) || g === 'unisex';
            if (slug.includes('gang-tay') && n.includes('gang-tay')) return slug.endsWith(g) || g === 'unisex';
            if ((slug.includes('that-lung') || slug.includes('day-lung')) && (n.includes('that-lung') || n.includes('day-lung'))) return slug.endsWith(g) || g === 'unisex';
        }
        
        if (slug.endsWith(g) || g === 'unisex' || g === 'tre-em') {
            if (slug.includes('ao-') && t === 'ao') {
                if (slug.includes('gio') && n.includes('gio')) return true;
                if (slug.includes('ni') && n.includes('ni')) return true;
                if (slug.includes('khoac') && n.includes('khoac')) return true;
                if (slug.includes('dai-tay') && n.includes('dai-tay')) return true;
                if (slug.includes('phao') && n.includes('phao')) return true;
                if (slug.includes('t-shirt') && (n.includes('t-shirt') || n.includes('thun'))) return true;
                if (slug.includes('polo') && n.includes('polo')) return true;
                if ((slug.includes('ba-lo') || slug.includes('tank')) && (n.includes('ba-lo') || n.includes('tank'))) return true;
                if (slug.includes('sat-nach') && n.includes('sat-nach')) return true;
                if (slug.includes('bra') && n.includes('bra')) return true;
            }
            if (slug.includes('quan-') && t === 'quan') {
                if (slug.includes('dai') && n.includes('dai')) return true;
                if (slug.includes('gio') && n.includes('gio')) return true;
                if (slug.includes('ni') && n.includes('ni')) return true;
                if (slug.includes('short') && n.includes('short')) return true;
                if (slug.includes('legging') && n.includes('legging')) return true;
                if (slug.includes('vay') && n.includes('vay')) return true;
            }
            if (slug.includes('giay-') && t === 'giay') {
                if (slug.includes('chay-bo') && (sp === 'chay-bo' || n.includes('chay-bo'))) return true;
                if (slug.includes('pickleball') && (sp === 'pickleball' || n.includes('pickleball'))) return true;
                if (slug.includes('tennis') && (sp === 'tennis' || n.includes('tennis'))) return true;
                if (slug.includes('golf') && (sp === 'golf' || n.includes('golf'))) return true;
                if (slug.includes('bong-ro') && (sp === 'bong-ro' || n.includes('bong-ro'))) return true;
                if (slug.includes('bong-da') && (sp === 'bong-da' || n.includes('bong-da'))) return true;
                if (slug.includes('cau-long') && (sp === 'cau-long' || n.includes('cau-long'))) return true;
                if (slug.includes('tap-luyen') && (sp === 'tap-luyen' || n.includes('tap-luyen'))) return true;
                if (slug.includes('thoi-trang')) return true;
            }
        }
        
        return false;
    };

    const addPath = (link: string, name: string) => {
        if (!link.startsWith('/chuyen-muc/')) return;
        const slug = link.replace('/chuyen-muc/', '');
        if(!paths.find((p: any) => p.params.slug === slug)) {
             const filteredProducts = productsData.filter((p: any) => checkProductMatch(p, slug));
             paths.push({
                 params: { slug },
                 props: { categoryName: name, products: filteredProducts },
             });
        }
    };

    vttData.menuItems.forEach((item: any) => {
        if (item.subItems) {
            item.subItems.forEach((subItem: any) => addPath(subItem.link, subItem.name));
        }
        if (item.subGroups) {
            item.subGroups.forEach((group: any) => {
                group.items.forEach((subItem: any) => addPath(subItem.link, subItem.name));
            });
        }
    });

    const extraRoutes = ['nam', 'nu', 'adidas', 'nike', 'asics', 'li-ning', 'le-coq-sportif', 'pickleball', 'cau-long', 'golf', 'bong-da', 'chay-bo', 'bong-ro', 'tap-luyen', 'tre-em'];
    for (const route of extraRoutes) {
       addPath(`/chuyen-muc/${route}`, route.toUpperCase().replace(/-/g, ' '));
    }

    // Route Sản Phẩm Mới (New Arrivals)
    paths.push({
        params: { slug: 'new-arrivals' },
        props: { categoryName: 'SẢN PHẨM MỚI', products: productsData.slice(0, 150) },
    });
    
    // Route Outlet (Khuyến Mãi)
    paths.push({
        params: { slug: 'outlet' },
        props: { categoryName: 'OUTLET', products: productsData.filter((p: any) => p.originalPrice > p.price) },
    });

    return paths;
}

const { categoryName, products } = Astro.props;

const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
};

// Phân tích các bộ lọc
const brandSet = new Set();
const sizeSet = new Set();
const sportSet = new Set();
const itemTypeSet = new Set();
const genderSet = new Set();

products.forEach((p: any) => {
    if(p.brand && p.brand !== 'Khác' && p.brand !== 'Maxxsport') brandSet.add(p.brand.toUpperCase());
    if(p.sizes) p.sizes.forEach((s: string) => sizeSet.add(s));
    
    // Dọn sport string
    let theSport = p.sport ? p.sport.trim() : 'Khác';
    if(theSport.startsWith('B-ng') || theSport.startsWith('bán')) theSport = 'Bóng rổ'; // fallback due to maxxsport typo
    if(theSport !== 'Khác') sportSet.add(theSport);
    
    if(p.itemType && p.itemType !== 'Khác') itemTypeSet.add(p.itemType);
    if(p.gender && p.gender !== 'Khác' && p.gender !== 'Mặc định' && p.gender !== 'Unisex') genderSet.add(p.gender);
});

const availableBrands = Array.from(brandSet).sort();
const availableSports = Array.from(sportSet).sort();
const availableItemTypes = Array.from(itemTypeSet).sort();
const availableGenders = Array.from(genderSet).sort();

const availableSizes = Array.from(sizeSet).sort();
const shoeSizes = availableSizes.filter(s => /^\d+(\.\d+)?(-)?$/.test(s as string) || /^[1-4][0-9]$/.test(s as string));
const clothSizes = availableSizes.filter(s => !shoeSizes.includes(s));
---

<BaseLayout title={`${categoryName} | Thể Thao Hoàng Hà`}>
    <!-- Breadcrumb -->
    <div class="bg-slate-50 border-b border-slate-200 py-2 w-full">
        <div class="max-w-7xl mx-auto px-4 flex items-center text-sm">
            <a href="/" class="text-slate-500 hover:text-primary-500 transition-colors">Trang chủ</a>
            <span class="mx-2 text-slate-300">/</span>
            <span class="text-slate-900 font-medium truncate">{categoryName}</span>
        </div>
    </div>

    <!-- Alpine Store Data for Client-Side Filtering -->
    <div 
        x-data="productFilter" 
        x-init={`initProducts(${JSON.stringify(products)})`}
        class="w-full max-w-7xl mx-auto px-4 py-8 lg:py-12"
    >
        <h1 class="bg-slate-900 text-white text-center py-2 md:py-3 text-[16px] md:text-xl font-medium tracking-wide mb-6 md:mb-10 uppercase">
            {categoryName}
        </h1>

        <div class="flex flex-col lg:flex-row gap-8 items-start">
            
            <!-- Sidebar Filter -->
            <aside class="w-full lg:w-[260px] flex-shrink-0 bg-white border-transparent p-0 lg:pr-5 sticky top-[100px]">
                <h3 class="font-normal text-[15px] mb-5 text-slate-900 border-b border-slate-200 pb-3 uppercase tracking-wide">BỘ LỌC</h3>
                
                <!-- Lọc Theo Thương Hiệu -->
                {availableBrands.length > 1 && (
                <div class="mb-6 border-b border-slate-100 pb-6" x-data="{ expanded: false }">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">THƯƠNG HIỆU</h4>
                    <div class="space-y-3.5">
                        {availableBrands.map((brand: any, index: number) => (
                            <label x-show={`expanded || ${index} < 5`} class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                                <input type="checkbox" value={brand} x-model="selectedBrands" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                                <span class="text-[14px] text-slate-800">{brand}</span>
                            </label>
                        ))}
                    </div>
                    {availableBrands.length > 5 && (
                        <button x-on:click="expanded = !expanded" class="mt-4 text-[13.5px] text-slate-800 hover:text-primary-600 flex items-center gap-1.5 focus:outline-none">
                            <span x-text="expanded ? 'Thu gọn' : 'Xem thêm'"></span>
                            <svg x-show="!expanded" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                            <svg x-show="expanded" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                        </button>
                    )}
                </div>
                )}

                <!-- Lọc Môn Thể thao -->
                {availableSports.length > 1 && (
                <div class="mb-6 border-b border-slate-100 pb-6" x-data="{ expanded: false }">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">DÒNG SẢN PHẨM</h4>
                    <div class="space-y-3.5">
                        {availableSports.map((sport: any, index: number) => (
                            <label x-show={`expanded || ${index} < 5`} class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                                <input type="checkbox" value={sport} x-model="selectedSports" x-on:change="applyFilters()" class="w-[16px] h-[16px] text-slate-800 bg-slate-100 border-slate-300 rounded-full focus:ring-0 focus:ring-offset-0 cursor-pointer">
                                <span class="text-[14px] text-slate-800 uppercase">{sport}</span>
                            </label>
                        ))}
                    </div>
                    {availableSports.length > 5 && (
                        <button x-on:click="expanded = !expanded" class="mt-4 text-[13.5px] text-slate-800 hover:text-primary-600 flex items-center gap-1.5 focus:outline-none">
                            <span x-text="expanded ? 'Thu gọn' : 'Xem thêm'"></span>
                            <svg x-show="!expanded" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                            <svg x-show="expanded" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                        </button>
                    )}
                </div>
                )}

                <!-- Mức Giá (Checkboxes like Maxxsport) -->
                <div class="mb-6 border-b border-slate-100 pb-6">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">MỨC GIÁ</h4>
                    <div class="space-y-3.5">
                        <label class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                            <input type="checkbox" value="<500" x-model="selectedPrices" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                            <span class="text-[14px] text-slate-800">Giá dưới 500.000₫</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                            <input type="checkbox" value="500-1000" x-model="selectedPrices" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                            <span class="text-[14px] text-slate-800">500.000₫ - 1.000.000₫</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                            <input type="checkbox" value="1000-2000" x-model="selectedPrices" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                            <span class="text-[14px] text-slate-800">1.000.000₫ - 2.000.000₫</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                            <input type="checkbox" value="2000-3000" x-model="selectedPrices" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                            <span class="text-[14px] text-slate-800">2.000.000₫ - 3.000.000₫</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                            <input type="checkbox" value="3000-5000" x-model="selectedPrices" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                            <span class="text-[14px] text-slate-800">3.000.000₫ - 5.000.000₫</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                            <input type="checkbox" value=">5000" x-model="selectedPrices" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                            <span class="text-[14px] text-slate-800">Giá trên 5.000.000₫</span>
                        </label>
                    </div>
                </div>

                <!-- Lọc Loại SP -->
                {availableItemTypes.length > 1 && (
                <div class="mb-6 border-b border-slate-100 pb-6" x-data="{ expanded: false }">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">LOẠI SẢN PHẨM</h4>
                    <div class="space-y-3.5">
                        {availableItemTypes.map((type: any, index: number) => (
                            <label x-show={`expanded || ${index} < 5`} class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                                <input type="checkbox" value={type} x-model="selectedItemTypes" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                                <span class="text-[14px] text-slate-800">{type}</span>
                            </label>
                        ))}
                    </div>
                    {availableItemTypes.length > 5 && (
                        <button x-on:click="expanded = !expanded" class="mt-4 text-[13.5px] text-slate-800 hover:text-primary-600 flex items-center gap-1.5 focus:outline-none">
                            <span x-text="expanded ? 'Thu gọn' : 'Xem thêm'"></span>
                            <svg x-show="!expanded" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                            <svg x-show="expanded" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                        </button>
                    )}
                </div>
                )}
                
                <!-- Lọc Giới tính -->
                {availableGenders.length > 1 && (
                <div class="mb-6 border-b border-slate-100 pb-6" x-data="{ expanded: false }">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">GIỚI TÍNH</h4>
                    <div class="space-y-3.5">
                        {availableGenders.map((gen: any, index: number) => (
                            <label x-show={`expanded || ${index} < 5`} class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors">
                                <input type="checkbox" value={gen} x-model="selectedGenders" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                                <span class="text-[14px] text-slate-800">{gen}</span>
                            </label>
                        ))}
                    </div>
                    {availableGenders.length > 5 && (
                        <button x-on:click="expanded = !expanded" class="mt-4 text-[13.5px] text-slate-800 hover:text-primary-600 flex items-center gap-1.5 focus:outline-none">
                            <span x-text="expanded ? 'Thu gọn' : 'Xem thêm'"></span>
                            <svg x-show="!expanded" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                            <svg x-show="expanded" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                        </button>
                    )}
                </div>
                )}

                <!-- Lọc Kích cỡ Quần áo -->
                {clothSizes.length > 0 && (
                <div class="mb-6 border-b border-slate-100 pb-6" x-data="{ expanded: false }">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">KÍCH CỠ QUẦN ÁO</h4>
                    <div class="grid grid-cols-2 gap-y-3 gap-x-1">
                        {clothSizes.map((size: any, index: number) => (
                            <label x-show={`expanded || ${index} < 6`} class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors w-full">
                                <input type="checkbox" value={size} x-model="selectedSizes" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                                <span class="text-[14px] text-slate-800 truncate">{size}</span>
                            </label>
                        ))}
                    </div>
                    {clothSizes.length > 6 && (
                        <button x-on:click="expanded = !expanded" class="mt-4 text-[13.5px] text-slate-800 hover:text-primary-600 flex items-center gap-1.5 focus:outline-none w-full">
                            <span x-text="expanded ? 'Thu gọn' : 'Xem thêm'"></span>
                            <svg x-show="!expanded" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                            <svg x-show="expanded" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                        </button>
                    )}
                </div>
                )}
                
                <!-- Lọc Kích cỡ Giày Dép -->
                {shoeSizes.length > 0 && (
                <div class="mb-6 border-b border-slate-100 pb-6" x-data="{ expanded: false }">
                    <h4 class="font-normal text-[14px] mb-4 text-slate-900 uppercase tracking-wide">KÍCH CỠ GIÀY DÉP</h4>
                    <div class="grid grid-cols-2 gap-y-3 gap-x-1">
                        {shoeSizes.map((size: any, index: number) => (
                            <label x-show={`expanded || ${index} < 6`} class="flex items-center gap-3 cursor-pointer hover:text-primary-600 transition-colors w-full">
                                <input type="checkbox" value={size} x-model="selectedSizes" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-slate-800 bg-white border-slate-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                                <span class="text-[14px] text-slate-800 truncate">{size}</span>
                            </label>
                        ))}
                    </div>
                    {shoeSizes.length > 6 && (
                        <button x-on:click="expanded = !expanded" class="mt-4 text-[13.5px] text-slate-800 hover:text-primary-600 flex items-center gap-1.5 focus:outline-none w-full">
                            <span x-text="expanded ? 'Thu gọn' : 'Xem thêm'"></span>
                            <svg x-show="!expanded" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                            <svg x-show="expanded" style="display:none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" /></svg>
                        </button>
                    )}
                </div>
                )}
                
                <!-- Filter Sale Option (Optional Extra for your UX) -->
                <div class="mb-6 pb-6 border-b border-slate-100">
                     <label class="flex items-center gap-3 cursor-pointer p-2.5 bg-rose-50/50 hover:bg-rose-50 border border-transparent rounded-[2px] transition-colors">
                        <input type="checkbox" x-model="showOnlySale" x-on:change="applyFilters()" class="w-[15px] h-[15px] text-rose-600 bg-white border-rose-300 rounded-[2px] focus:ring-0 focus:ring-offset-0 cursor-pointer">
                        <span class="text-[14px] font-medium text-rose-600 mt-0.5">🔥 Chỉ xem Sản phẩm Sale</span>
                    </label>
                </div>
                
                <button x-on:click="resetFilters()" class="w-full mt-2 lg:mt-6 py-2.5 bg-slate-900 hover:bg-primary-600 text-white transition-colors font-medium text-[13px] rounded-sm tracking-wide uppercase">
                    Xoá tất cả bộ lọc
                </button>
            </aside>

            <!-- Main Content Area (Products Grid & Sort Dropdown) -->
            <div class="flex-grow w-full">
                <!-- Toolbar (Shows Total Count & Sort Input Desktop) -->
                <div class="flex items-center justify-between mb-6 bg-slate-50 border border-slate-100 p-3 lg:px-4 lg:py-2 rounded-sm gap-4">
                    <p class="text-slate-500 text-[13px]">
                        Tìm thấy <span x-text="filteredProducts.length"></span> sản phẩm.
                    </p>
                    <div class="flex items-center gap-3 w-full lg:w-auto overflow-x-auto shrink-0 justify-end">
                        <span class="text-[13px] font-medium text-slate-500 uppercase shrink-0">SẮP XẾP:</span>
                        <select x-model="sortOrder" x-on:change="applyFilters()" class="bg-white border text-[13px] border-slate-200 text-slate-700 rounded-sm focus:ring-primary-500 focus:border-primary-500 block px-3 py-1.5 cursor-pointer outline-none min-w-[170px]">
                            <option value="default">Mặc định (Mới nhất)</option>
                            <option value="price-asc">Giá: Thấp tới Cao</option>
                            <option value="price-desc">Giá: Cao tới Thấp</option>
                            <option value="name-asc">Tên: A-Z</option>
                        </select>
                    </div>
                </div>

                <!-- Grid Render Zone -->
                <div x-show="filteredProducts.length > 0" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3 md:gap-5" id="productGridContainer">
                    <template x-for="p in filteredProducts" :key="p.id">
                        <div class="group bg-white rounded flex flex-col h-full relative cursor-pointer hover:shadow-lg transition-shadow duration-300 block border border-transparent hover:border-slate-200">
                            <a :href="`/san-pham/${p.id}`" class="absolute inset-0 z-10 block opacity-0">View</a>
                            
                            <!-- Image -->
                            <div class="relative w-full aspect-square bg-white flex-shrink-0">
                                <img 
                                    :src="p.image" 
                                    :alt="p.name"
                                    class="w-full h-full object-contain p-2"
                                    loading="lazy"
                                />
                                <template x-if="p.originalPrice && p.originalPrice > p.price">
                                    <div class="absolute top-2 left-2 bg-primary-500 text-white text-[10px] sm:text-xs font-bold px-2 py-0.5 uppercase z-20 shadow-sm rounded-sm">
                                        Sale
                                    </div>
                                </template>
                            </div>

                            <!-- Content -->
                            <div class="p-3 flex flex-col flex-grow items-center text-center">
                                <h3 class="text-[13px] sm:text-sm font-medium text-slate-800 leading-snug mb-1 line-clamp-2 max-h-[2.6rem] group-hover:text-primary-500 transition-colors" x-text="p.name">
                                </h3>

                                <div class="mt-auto flex items-center justify-center gap-2 mb-3">
                                    <span class="text-sm md:text-[15px] font-bold text-primary-500" x-text="formatCurrency(p.price)"></span>
                                    <template x-if="p.originalPrice && p.originalPrice > p.price">
                                        <del class="text-[11px] text-slate-400 font-medium" x-text="formatCurrency(p.originalPrice)"></del>
                                    </template>
                                </div>
                                
                                <a :href="`https://zalo.me/0964534299?text=Tôi+cần+mua+${encodeURIComponent(p.name)}`" 
                                   target="_blank" 
                                   rel="noopener noreferrer"
                                   class="inline-flex z-20 items-center justify-center bg-transparent border border-zalo hover:bg-zalo text-zalo hover:text-white text-[11px] sm:text-[13px] font-semibold py-1.5 px-4 sm:px-6 rounded-full transition-colors w-max mx-auto shadow-sm tracking-wide">
                                    Tư vấn ngay
                                </a>
                            </div>
                        </div>
                    </template>
                </div>

                <!-- Empty State -->
                <div x-show="filteredProducts.length === 0" style="display: none;" class="text-center py-20 text-slate-500 bg-slate-50 rounded-xl border border-dashed border-slate-200">
                    <svg class="mx-auto h-12 w-12 text-slate-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <p class="text-[15px] text-slate-600 font-medium">Lọc tìm không thấy sản phẩm nào phù hợp.</p>
                    <button x-on:click="resetFilters()" class="text-primary-600 font-bold hover:underline mt-2 inline-block text-[13px]">Xoá toàn bộ bộ lọc ngay</button>
                </div>

            </div>
        </div>
    </div>
</BaseLayout>

<!-- Client Config -->
<script is:inline>
    document.addEventListener('alpine:init', () => {
        Alpine.data('productFilter', () => ({
            allProducts: [],
            filteredProducts: [],
            
            // Filter states
            selectedBrands: [],
            selectedSizes: [],
            selectedSports: [],
            selectedItemTypes: [],
            selectedGenders: [],
            selectedPrices: [],
            showOnlySale: false,
            sortOrder: 'default',

            initProducts(data) {
                this.allProducts = data;
                this.filteredProducts = [...data];
            },

            formatCurrency(amount) {
                return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
            },

            applyFilters() {
                let result = [...this.allProducts];

                // Brand
                if (this.selectedBrands.length > 0) {
                    result = result.filter(p => p.brand && this.selectedBrands.includes(p.brand.toUpperCase()));
                }

                // Sizes
                if (this.selectedSizes.length > 0) {
                    result = result.filter(p => p.sizes && p.sizes.some(s => this.selectedSizes.includes(s)));
                }

                // Sports
                if (this.selectedSports.length > 0) {
                    result = result.filter(p => p.sport && this.selectedSports.includes(p.sport));
                }
                
                // Item Types
                if (this.selectedItemTypes.length > 0) {
                    result = result.filter(p => p.itemType && this.selectedItemTypes.includes(p.itemType));
                }
                
                // Genders
                if (this.selectedGenders.length > 0) {
                    result = result.filter(p => p.gender && this.selectedGenders.includes(p.gender));
                }

                // Price ranges
                if (this.selectedPrices.length > 0) {
                    result = result.filter(p => {
                        const price = p.price;
                        return this.selectedPrices.some(range => {
                            if (range === '<500') return price < 500000;
                            if (range === '500-1000') return price >= 500000 && price <= 1000000;
                            if (range === '1000-2000') return price > 1000000 && price <= 2000000;
                            if (range === '2000-3000') return price > 2000000 && price <= 3000000;
                            if (range === '3000-5000') return price > 3000000 && price <= 5000000;
                            if (range === '>5000') return price > 5000000;
                            return false;
                        });
                    });
                }

                // Sale
                if (this.showOnlySale) {
                    result = result.filter(p => p.originalPrice > p.price);
                }

                // Sorting
                switch (this.sortOrder) {
                    case 'price-asc':
                        result.sort((a, b) => a.price - b.price);
                        break;
                    case 'price-desc':
                        result.sort((a, b) => b.price - a.price);
                        break;
                    case 'name-asc':
                        result.sort((a, b) => a.name.localeCompare(b.name));
                        break;
                    default:
                        // No sort
                        break;
                }

                this.filteredProducts = result;
            },

            resetFilters() {
                this.selectedBrands = [];
                this.selectedSizes = [];
                this.selectedSports = [];
                this.selectedItemTypes = [];
                this.selectedGenders = [];
                this.selectedPrices = [];
                this.showOnlySale = false;
                this.sortOrder = 'default';
                this.applyFilters();
            }
        }));
    });
</script>
